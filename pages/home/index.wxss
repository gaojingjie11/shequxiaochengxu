.home-page {
  min-height: 100vh;
}

.hero {
  position: relative;
  padding: 34px 0 28px;
  background: linear-gradient(135deg, #2d597b 0%, #276193 58%, #3e78a8 100%);
  color: #fff;
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  width: 220px;
  height: 220px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  top: -90px;
  right: -30px;
}

.hero::after {
  content: "";
  position: absolute;
  width: 160px;
  height: 160px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  bottom: -80px;
  left: -40px;
}

.hero-title,
.hero-subtitle,
.hero-tags {
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 27px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.hero-subtitle {
  margin-top: 8px;
  font-size: 14px;
  opacity: 0.92;
}

.hero-tags {
  margin-top: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.hero-tag {
  padding: 4px 12px;
  border-radius: 999px;
  font-size: 12px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.12);
}

.home-content {
  margin-top: -12px;
  padding-bottom: 24px;
}

.section-header {
  margin: 18px 0 12px;
}

.section-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  margin-top: 4px;
  font-size: 13px;
  color: var(--text-secondary);
}

.quick-menu {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.quick-item {
  margin-bottom: 0;
  text-align: center;
  padding: 18px 12px;
}

.quick-icon-wrap {
  width: 52px;
  height: 52px;
  margin: 0 auto 10px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef5fc;
}

.quick-icon {
  font-size: 24px;
}

.quick-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.notice-header {
  margin-top: 24px;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.notice-item {
  margin-bottom: 0;
}

.notice-tag {
  display: inline-block;
  margin-bottom: 8px;
  padding: 2px 10px;
  border-radius: 999px;
  font-size: 12px;
  color: var(--primary-color);
  background: var(--primary-soft);
}

.notice-title {
  font-size: 16px;
  color: var(--text-primary);
  font-weight: 700;
  line-height: 1.5;
}

.notice-meta {
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px dashed var(--border-color);
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-tertiary);
}

.empty-state {
  margin-bottom: 0;
  text-align: center;
  color: var(--text-secondary);
  padding: 18px 0;
}
