.create-order-page {
  min-height: 100vh;
  padding: 12px 0 84px;
  background: var(--bg-page);
}

.page-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.section {
  margin: 0 0 12px;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  margin-bottom: 10px;
  color: var(--text-primary);
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border-color);
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  font-size: 14px;
  color: var(--text-primary);
}

.arrow {
  color: var(--text-tertiary);
}

.store-address {
  font-size: 12px;
  color: var(--text-secondary);
}

.item {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.item:last-child {
  margin-bottom: 0;
}

.item-img {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  background: #e8eef5;
  margin-right: 10px;
}

.item-info {
  flex: 1;
}

.name {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.price {
  font-size: 12px;
  color: var(--text-secondary);
}

.item-total {
  font-weight: 700;
  font-size: 14px;
  color: #c74545;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px calc(10px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--border-color);
  z-index: 20;
}

.total-info {
  font-size: 13px;
  color: var(--text-secondary);
}

.total-price {
  color: #c74545;
  font-size: 20px;
  font-weight: 700;
  margin-left: 6px;
}

.submit-btn {
  margin: 0;
  min-width: 130px;
}
