<view class="order-page">
  <view class="mix-pay-tip card" wx:if="{{userInfo}}">
    <view class="tip-title">混合支付已启用（{{greenPointsPerYuan}} 积分 = 1 元）</view>
    <view class="tip-desc">系统会优先扣除绿色积分，不足部分再扣除余额。</view>
    <view class="tip-desc">当前绿色积分 {{userInfo.green_points || 0}}，余额 ￥{{userBalanceText}}</view>
  </view>

  <view class="tabs">
    <block wx:for="{{tabs}}" wx:key="status">
      <view class="tab-item {{currentTabStatus === item.status ? 'active' : ''}}" bindtap="switchTab" data-status="{{item.status}}">
        {{item.name}}
      </view>
    </block>
  </view>

  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card card" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="order-header">
          <text class="order-no">单号: {{item.order_no}}</text>
          <text class="order-status {{item.status === 1 ? 'text-success' : (item.status === 0 ? 'text-warning' : '')}}">
            {{statusMap[item.status]}}
          </text>
        </view>

        <view class="order-body">
          <block wx:for="{{item.items}}" wx:key="id" wx:for-item="prod">
            <view class="prod-row">
              <image class="prod-img" src="{{prod.product.image_url || '/assets/icons/mall.png'}}" mode="aspectFill"></image>
              <view class="prod-info">
                <view class="prod-name">{{prod.product.name}}</view>
                <view class="prod-meta">￥{{prod.price}} x {{prod.quantity}}</view>
              </view>
            </view>
          </block>
        </view>

        <view class="payment-info">
          <text>总额 ￥{{item.total_amount_text}}</text>
          <text wx:if="{{item.status === 0}}">预计抵扣积分 {{item.payment_preview.points}}</text>
          <text wx:if="{{item.status === 0}}">预计余额支付 ￥{{item.payment_preview.balance_text}}</text>
          <text wx:if="{{item.used_points > 0}}">积分抵扣 {{item.used_points}}</text>
          <text wx:if="{{item.used_balance > 0}}">余额支付 ￥{{item.used_balance_text}}</text>
        </view>

        <view class="order-footer">
          <view class="total-row">共{{item.items.length}}件商品</view>
          <view class="action-row">
            <button class="btn-mini btn-danger" wx:if="{{item.status === 0}}" catchtap="payOrder" data-id="{{item.id}}">立即支付</button>
            <button class="btn-mini" wx:if="{{item.status === 0}}" catchtap="cancelOrder" data-id="{{item.id}}">取消</button>
            <button class="btn-mini btn-primary" wx:if="{{item.status === 2}}" catchtap="confirmReceipt" data-id="{{item.id}}">确认收货</button>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{!loading && orders.length === 0}}" class="empty-state">暂无订单</view>
  </view>
</view>
