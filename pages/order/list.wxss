.order-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 8px;
}

.mix-pay-tip {
  margin: 12px;
  background: #eef8ef;
  border: 1px solid #cde8d1;
}

.tip-title {
  font-size: 14px;
  color: #227b58;
  font-weight: 700;
  margin-bottom: 6px;
}

.tip-desc {
  color: #3d7d61;
  font-size: 12px;
  line-height: 1.6;
}

.tabs {
  display: flex;
  gap: 8px;
  padding: 0 12px 10px;
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--bg-page);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 7px 0;
  font-size: 13px;
  color: var(--text-secondary);
  border-radius: 999px;
  background: #e9eff6;
}

.tab-item.active {
  color: #fff;
  background: var(--primary-color);
  font-weight: 600;
}

.order-list {
  padding: 0 12px 14px;
}

.order-card {
  margin-bottom: 12px;
  border-radius: 14px;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  font-size: 12px;
  border-bottom: 1px solid var(--border-color);
  padding-bottom: 8px;
}

.order-no {
  color: var(--text-secondary);
}

.order-status {
  font-weight: 700;
}

.text-success {
  color: #1f9d72;
}

.text-warning {
  color: #c47b00;
}

.prod-row {
  display: flex;
  margin-bottom: 10px;
}

.prod-row:last-child {
  margin-bottom: 0;
}

.prod-img {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  background: #e8eef5;
  margin-right: 10px;
}

.prod-info {
  flex: 1;
}

.prod-name {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.prod-meta {
  color: var(--text-secondary);
  font-size: 12px;
}

.payment-info {
  margin-top: 10px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px 8px;
  color: var(--text-secondary);
  font-size: 12px;
}

.order-footer {
  margin-top: 10px;
  border-top: 1px solid var(--border-color);
  padding-top: 10px;
}

.total-row {
  text-align: right;
  font-size: 13px;
  margin-bottom: 10px;
  color: var(--text-primary);
}

.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.btn-mini {
  margin: 0;
  min-height: 30px;
  line-height: 30px;
  font-size: 12px;
  padding: 0 12px;
  border-radius: 999px;
  background: #fff;
  border: 1px solid var(--border-strong);
  color: var(--text-secondary);
}

.btn-mini::after {
  border: none;
}

.btn-danger {
  color: var(--danger-color);
  border-color: #f2c2c2;
  background: #fff3f3;
}

.btn-primary {
  color: var(--primary-color);
  border-color: #b7d1e8;
  background: #edf5fd;
}

.empty-state {
  text-align: center;
  padding: 48px 0 22px;
  color: var(--text-tertiary);
}
