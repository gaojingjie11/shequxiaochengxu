.container {
  min-height: 100vh;
  padding: 12px;
  background: var(--bg-page);
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.product-item {
  margin-bottom: 0;
  display: flex;
  padding: 12px;
}

.product-img {
  width: 86px;
  height: 86px;
  border-radius: 10px;
  margin-right: 10px;
  background: #e8eef5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.product-price {
  font-size: 18px;
  color: #c74545;
  font-weight: 700;
}

.action-row {
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  font-size: 12px;
  color: var(--text-secondary);
  padding: 3px 12px;
  border: 1px solid var(--border-strong);
  border-radius: 999px;
  background: #f7fafc;
}

.empty-state {
  padding-top: 90px;
  text-align: center;
}

.empty-icon {
  width: 100px;
  height: 100px;
  margin-bottom: 10px;
  opacity: 0.72;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 14px;
}
