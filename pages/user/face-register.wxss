.face-register-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 12px;
}

.status-card,
.action-card {
  margin-bottom: 12px;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary);
}

.status-tag {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
}

.status-tag.is-registered {
  color: #1f9d72;
  background: #e9f8f2;
}

.status-tag.is-unregistered {
  color: #a36a00;
  background: #fff8e8;
}

.desc {
  margin-top: 10px;
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.7;
}

.capture-btn {
  width: 100%;
}

.tip {
  margin-top: 10px;
  font-size: 12px;
  color: var(--text-tertiary);
  text-align: center;
}
