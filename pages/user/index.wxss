.user-page {
  min-height: 100vh;
  padding-bottom: 22px;
}

.profile-hero {
  background: linear-gradient(135deg, #2d597b 0%, #376f9f 68%, #4c87b8 100%);
  color: #fff;
  padding: 28px 0 20px;
}

.profile-title {
  font-size: 24px;
  font-weight: 700;
}

.profile-subtitle {
  margin-top: 6px;
  font-size: 13px;
  opacity: 0.92;
}

.profile-main {
  margin-top: 10px;
}

.user-header {
  padding: 18px;
}

.user-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.avatar {
  width: 68px;
  height: 68px;
  border-radius: 50%;
  margin-right: 14px;
  background: #e8eef5;
  border: 2px solid #eef3f8;
}

.info-col {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.name {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
}

.role-tag {
  font-size: 11px;
  color: var(--primary-color);
  background: var(--primary-soft);
  border-radius: 999px;
  padding: 2px 8px;
}

.mobile {
  margin-top: 6px;
  display: block;
  font-size: 13px;
  color: var(--text-secondary);
}

.stats-row {
  display: flex;
  padding-top: 14px;
  border-top: 1px solid var(--border-color);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 12px;
  color: var(--text-tertiary);
}

.stat-val {
  margin-top: 4px;
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary);
}

.unlogin-view {
  display: flex;
  align-items: center;
  padding: 4px 0;
}

.login-text {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.menu-item {
  margin-bottom: 0;
  text-align: center;
  padding: 18px 12px;
  min-height: 116px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  font-size: 28px;
  margin-bottom: 8px;
}

.menu-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.face-status {
  margin-top: 8px;
  font-size: 11px;
  padding: 2px 9px;
  border-radius: 999px;
}

.face-status.is-registered {
  color: #0f7a58;
  background: #e8f8f1;
}

.face-status.is-unregistered {
  color: #a36a00;
  background: #fff7e7;
}
