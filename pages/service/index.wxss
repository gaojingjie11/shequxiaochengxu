.service-page {
  min-height: 100vh;
}

.service-hero {
  background: linear-gradient(135deg, #2d597b 0%, #2f699a 65%, #4c86b8 100%);
  color: #fff;
  padding: 30px 0 24px;
}

.service-title {
  font-size: 26px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.service-subtitle {
  margin-top: 8px;
  opacity: 0.92;
  font-size: 14px;
}

.service-main {
  margin-top: -8px;
  padding-top: 16px;
  padding-bottom: 24px;
}

.service-menu {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.service-card {
  margin-bottom: 0;
  text-align: left;
  padding: 16px 14px;
}

.service-icon-wrap {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf4fb;
  margin-bottom: 12px;
}

.service-icon {
  font-size: 24px;
  line-height: 1;
}

.service-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.service-desc {
  font-size: 12px;
  color: var(--text-secondary);
  line-height: 1.5;
}
