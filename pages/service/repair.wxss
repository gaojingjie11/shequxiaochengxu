.repair-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 12px;
}

.page-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.repair-form {
  margin-bottom: 18px;
  padding: 16px;
}

.form-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 14px;
  color: var(--text-primary);
}

.form-group {
  margin-bottom: 12px;
  position: relative;
}

.label {
  display: block;
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

.picker-val {
  width: 100%;
  min-height: 42px;
  border: 1px solid var(--border-strong);
  border-radius: 12px;
  padding: 10px 12px;
  background: #f9fbfd;
  color: var(--text-primary);
}

.arrow {
  position: absolute;
  right: 12px;
  top: 36px;
  color: var(--text-tertiary);
}

.input,
.textarea {
  width: 100%;
  border: 1px solid var(--border-strong);
  border-radius: 12px;
  padding: 10px 12px;
  font-size: 14px;
  background: #f9fbfd;
  color: var(--text-primary);
}

.textarea {
  min-height: 100px;
}

.btn-submit {
  margin-top: 6px;
}

.section-title {
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 10px;
  color: var(--text-primary);
}

.repair-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.repair-card {
  margin-bottom: 0;
}

.repair-header {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
  gap: 8px;
}

.repair-category {
  font-weight: 700;
  flex: 1;
  color: var(--text-primary);
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  font-size: 12px;
  padding: 2px 9px;
}

.tag-info {
  background: #edf4fb;
  color: var(--primary-color);
}

.tag-warning {
  background: #fff8e8;
  color: #a36a00;
}

.tag-status {
  background: #eef3f8;
  color: var(--text-secondary);
}

.repair-content {
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.7;
}

.repair-result {
  margin-top: 10px;
  padding: 8px 10px;
  border-radius: 10px;
  background: #f7fafc;
  color: var(--text-secondary);
  font-size: 13px;
}

.bold {
  color: var(--text-primary);
  font-weight: 600;
}

.repair-time {
  margin-top: 10px;
  font-size: 12px;
  color: var(--text-tertiary);
}

.empty-state {
  text-align: center;
  color: var(--text-tertiary);
  padding: 34px 0 20px;
}
