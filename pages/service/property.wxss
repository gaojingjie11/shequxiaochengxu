.container {
  min-height: 100vh;
  padding: 12px;
  background: var(--bg-page);
}

.mix-pay-tip {
  margin-bottom: 12px;
  background: #eef8ef;
  border: 1px solid #cde8d1;
}

.tip-title {
  color: #227b58;
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 6px;
}

.tip-desc {
  color: #3d7d61;
  font-size: 12px;
  line-height: 1.6;
}

.tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 13px;
  border-radius: 999px;
  color: var(--text-secondary);
  background: #e9eff6;
}

.tab-item.active {
  color: #fff;
  background: var(--primary-color);
  font-weight: 600;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.fee-card {
  margin-bottom: 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 10px;
  border-bottom: 1px dashed var(--border-color);
}

.title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary);
}

.amount {
  font-size: 20px;
  font-weight: 700;
  color: #c74545;
}

.row {
  display: flex;
  margin-bottom: 6px;
  font-size: 13px;
}

.label {
  color: var(--text-secondary);
  width: 92px;
}

.val {
  color: var(--text-primary);
}

.footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--border-color);
}

.pay-btn {
  margin: 0;
  min-height: 32px;
  line-height: 32px;
  border-radius: 999px;
  padding: 0 14px;
  background: var(--primary-color) !important;
}

.pay-btn::after {
  border: none;
}

.status-tag {
  font-size: 12px;
  color: #1f9d72;
  background: #e9f8f2;
  padding: 3px 10px;
  border-radius: 999px;
}

.empty-state {
  text-align: center;
  padding: 56px 0 24px;
  color: var(--text-tertiary);
}

.empty-icon {
  width: 90px;
  opacity: 0.65;
  margin-bottom: 12px;
}
