.community-chat-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 12px;
  box-sizing: border-box;
}

.chat-card {
  height: calc(100vh - 24px);
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow: hidden;
}

.chat-list {
  flex: 1;
  min-height: 0;
  padding: 12px;
  box-sizing: border-box;
  background: #f8fbff;
}

.state-text {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 13px;
  padding: 24px 0;
}

.message-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-bottom: 12px;
}

.message-item.is-self {
  flex-direction: row-reverse;
}

.avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #e2edf8;
}

.bubble-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.message-item.is-self .bubble-wrap {
  align-items: flex-end;
}

.meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.name {
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
}

.time {
  font-size: 11px;
  color: var(--text-tertiary);
}

.bubble {
  max-width: 78%;
  background: #fff;
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 9px 12px;
  font-size: 14px;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.message-item.is-self .bubble {
  background: linear-gradient(135deg, #47719b 0%, #2d597b 100%);
  border-color: transparent;
  color: #fff;
}

.composer {
  border-top: 1px solid var(--border-color);
  padding: 10px;
  background: #fff;
  position: relative;
  z-index: 2;
}

.composer-input {
  width: 100%;
  min-height: 70px;
  background: #f7fafc;
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 10px;
  font-size: 14px;
  color: var(--text-primary);
}

.composer-actions {
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hint {
  font-size: 11px;
  color: var(--text-tertiary);
}

.send-btn {
  min-width: 84px;
  margin: 0;
}

.bottom-anchor {
  height: 2px;
}
