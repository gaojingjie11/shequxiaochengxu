.container {
  min-height: 100vh;
  padding: 12px;
  background: var(--bg-page);
}

.header-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
}

.status-badge {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
}

.status-has {
  background: #e9f8f2;
  color: #1f9d72;
}

.status-none {
  background: #eef3f8;
  color: var(--text-secondary);
}

.info-card {
  margin-bottom: 10px;
}

.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  font-size: 14px;
}

.info-item:last-child {
  margin-bottom: 0;
}

.label {
  color: var(--text-secondary);
}

.value {
  color: var(--text-primary);
  font-weight: 600;
}

.footer-btn {
  margin-top: 10px;
  text-align: right;
}

.bind-btn {
  margin: 0;
  border-radius: 999px;
  min-height: 30px;
  line-height: 30px;
  background: var(--primary-color) !important;
}

.bind-btn::after {
  border: none;
}

.empty-state {
  text-align: center;
  padding: 26px 14px;
}

.empty-icon {
  width: 90px;
  opacity: 0.65;
  margin-bottom: 10px;
}

.empty-text {
  color: var(--text-primary);
  font-size: 15px;
  font-weight: 700;
}

.empty-sub {
  margin-top: 6px;
  color: var(--text-secondary);
  font-size: 12px;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.38);
  z-index: 98;
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  width: 84%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  z-index: 99;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10px;
}

.modal-input {
  width: 100%;
  min-height: 44px;
  border: 1px solid var(--border-strong);
  border-radius: 12px;
  padding: 10px 12px;
  font-size: 14px;
  background: #f9fbfd;
}

.modal-footer {
  margin-top: 12px;
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.btn-cancel,
.btn-confirm {
  margin: 0;
  min-width: 80px;
  min-height: 34px;
  border-radius: 999px;
  font-size: 13px;
}

.btn-cancel {
  color: var(--text-secondary);
  background: #eef3f8;
}

.btn-confirm {
  color: #fff;
  background: var(--primary-color);
}

.btn-cancel::after,
.btn-confirm::after {
  border: none;
}
