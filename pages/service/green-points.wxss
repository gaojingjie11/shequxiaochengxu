.green-points-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 12px;
}

.hero {
  margin-bottom: 12px;
  background: linear-gradient(135deg, #f5faff 0%, #edf4fb 100%);
}

.hero-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
}

.hero-desc {
  margin-top: 8px;
  color: var(--text-secondary);
  font-size: 13px;
}

.hero-stats {
  margin-top: 12px;
  display: flex;
  gap: 10px;
}

.stat {
  flex: 1;
  background: #fff;
  border-radius: 12px;
  border: 1px solid var(--border-color);
  padding: 10px;
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.stat-value {
  margin-top: 4px;
  font-size: 20px;
  font-weight: 700;
  color: var(--primary-color);
}

.section-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 12px;
}

.preview-wrap {
  width: 100%;
  height: 220px;
  border: 1px dashed var(--border-strong);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 12px;
  background: #f8fbff;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.btn-row {
  display: flex;
  gap: 10px;
}

.btn-row .btn {
  flex: 1;
}

.result-box {
  margin-top: 12px;
  background: #eef8ef;
  border: 1px solid #cde8d1;
  border-radius: 12px;
  padding: 10px;
}

.result-title {
  color: #207b58;
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 6px;
}

.result-text {
  color: #3d7d61;
  font-size: 13px;
  line-height: 1.6;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 9px 0;
  border-bottom: 1px dashed var(--border-color);
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-no {
  width: 40px;
  font-size: 13px;
  font-weight: 700;
  color: var(--primary-color);
}

.rank-avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  margin-right: 8px;
  background: #e8eef5;
}

.rank-name {
  flex: 1;
  font-size: 14px;
  color: var(--text-primary);
}

.rank-score {
  font-size: 13px;
  color: #1f9d72;
  font-weight: 700;
}

.loading,
.empty {
  text-align: center;
  color: var(--text-tertiary);
  padding: 16px 0;
  font-size: 12px;
}
