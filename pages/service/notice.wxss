.notice-page {
  min-height: 100vh;
  padding: 12px 0 18px;
}

.notice-head {
  margin-bottom: 12px;
  background: linear-gradient(135deg, #f5faff 0%, #edf4fb 100%);
}

.notice-title-main {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
}

.notice-subtitle {
  margin-top: 6px;
  font-size: 12px;
  color: var(--text-secondary);
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.notice-card {
  margin-bottom: 0;
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.notice-tag {
  display: inline-block;
  font-size: 12px;
  color: var(--primary-color);
  background: var(--primary-soft);
  border-radius: 999px;
  padding: 2px 10px;
}

.notice-meta {
  font-size: 12px;
  color: var(--text-tertiary);
  display: flex;
  gap: 10px;
}

.notice-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--text-primary);
}

.notice-content {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.7;
}

.notice-footer {
  padding-top: 10px;
  margin-top: 10px;
  border-top: 1px dashed var(--border-color);
  font-size: 12px;
  color: var(--text-tertiary);
}

.loading-text,
.no-more,
.empty-state {
  text-align: center;
  padding: 18px;
  color: var(--text-tertiary);
  font-size: 12px;
}
