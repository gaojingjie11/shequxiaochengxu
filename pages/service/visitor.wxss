.container {
  min-height: 100vh;
  padding: 12px;
  background: var(--bg-page);
}

.tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 13px;
  color: var(--text-secondary);
  background: #e9eff6;
  border-radius: 999px;
}

.tab-item.active {
  color: #fff;
  background: var(--primary-color);
  font-weight: 600;
}

.form-card {
  margin-bottom: 0;
}

.form-item {
  margin-bottom: 12px;
}

.label {
  display: block;
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

.submit-btn {
  margin-top: 6px;
}

.refresh-btn {
  margin-bottom: 10px;
  border-radius: 999px;
  border: 1px solid #c8dbed;
  color: var(--primary-color);
  background: #edf4fb;
}

.refresh-btn::after {
  border: none;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.history-item {
  margin-bottom: 0;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.name {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary);
}

.sub {
  font-size: 12px;
  color: var(--text-secondary);
}

.reason {
  font-size: 13px;
  color: var(--text-primary);
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px dashed var(--border-color);
}

.status {
  font-size: 12px;
  border-radius: 999px;
  padding: 2px 9px;
}

.status-0 {
  background: #fff8e8;
  color: #a36a00;
}

.status-1 {
  background: #e9f8f2;
  color: #1f9d72;
}

.status-2 {
  background: #fff1f1;
  color: #c74545;
}

.empty-text {
  text-align: center;
  color: var(--text-tertiary);
  padding: 24px 0;
}
