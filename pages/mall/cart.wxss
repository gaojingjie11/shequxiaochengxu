.cart-page {
  padding: 12px 12px 90px;
  min-height: 100vh;
  background: var(--bg-page);
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cart-item {
  margin: 0;
  display: flex;
  align-items: center;
  padding: 14px;
}

.item-image {
  width: 72px;
  height: 72px;
  border-radius: 10px;
  background: #e8eef5;
  margin-right: 10px;
}

.item-info {
  flex: 1;
  margin-right: 10px;
}

.item-name {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-price {
  color: #c74545;
  font-weight: 700;
  font-size: 14px;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 1px solid var(--border-strong);
  border-radius: 999px;
  height: 30px;
  background: #f8fafc;
}

.qty-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 16px;
}

.qty-num {
  width: 28px;
  text-align: center;
  font-size: 12px;
  color: var(--text-primary);
}

.delete-btn {
  margin-left: 10px;
  font-size: 12px;
  color: var(--text-tertiary);
}

.empty-state {
  text-align: center;
  padding-top: 100px;
}

.empty-icon {
  font-size: 48px;
}

.empty-text {
  margin-top: 10px;
  color: var(--text-secondary);
}

.mt-md {
  margin-top: 16px;
  display: inline-flex;
  min-width: 120px;
}

.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid var(--border-color);
  padding: 10px 12px calc(10px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.total-info {
  color: var(--text-secondary);
  font-size: 14px;
}

.total-price {
  margin-left: 6px;
  color: #c74545;
  font-size: 18px;
  font-weight: 700;
}

.checkout-btn {
  min-width: 120px;
}
