/* pages/mall/detail.wxss */
.detail-page {
  padding-bottom: 80px;
  background: #f7f8fa;
  min-height: 100vh;
}

.detail-image {
  width: 100%;
  height: 750rpx;
  background: #fff;
}

.detail-info {
  background: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.detail-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #333;
}

.detail-desc {
  font-size: 14px;
  color: #666;
  margin-bottom: 12px;
  line-height: 1.5;
}

.detail-price {
  margin-bottom: 12px;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 14px;
  color: #ff4d4f;
}

.price-val {
  font-size: 24px;
  font-weight: 700;
  color: #ff4d4f;
}

.price-original {
  font-size: 12px;
  color: #999;
  text-decoration: line-through;
  margin-left: 8px;
}

.promo-tag {
  font-size: 10px;
  color: #ff4d4f;
  border: 1px solid #ff4d4f;
  padding: 0 4px;
  border-radius: 4px;
  margin-left: 8px;
}

.detail-meta {
  display: flex;
  font-size: 12px;
  color: #999;
}

.meta-item {
  margin-right: 20px;
}

.comments-section {
  background: #fff;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  border-left: 4px solid var(--primary-color);
  padding-left: 8px;
}

.comment-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #eee;
}

.comment-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  margin-right: 12px;
  background: #eee;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4px;
  font-size: 12px;
}

.username {
  color: #333;
  font-weight: 500;
}

.time {
  color: #999;
}

.comment-content {
  font-size: 14px;
  color: #666;
}

.empty-comment {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 12px;
}

.bottom-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 2px;
}

.fav-active {
  color: #ffcc00;
}

.btn-cart {
  margin-left: auto;
  background: var(--primary-color);
  color: #fff;
  border-radius: 20px;
  padding: 8px 32px;
  font-size: 14px;
}
