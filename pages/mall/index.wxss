/* pages/mall/index.wxss */
.mall-page {
  background: #f7f8fa;
  min-height: 100vh;
}

.search-section {
  background: #fff;
  padding: 10px 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  background: #f2f2f2;
  border-radius: 18px;
  height: 36px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}

.search-icon {
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: 14px;
}

.category-scroll {
  white-space: nowrap;
  background: #fff;
  padding: 0 8px;
  height: 44px;
  display: flex;
  align-items: center;
  border-bottom: 1px solid #f0f0f0;
}

.category-item {
  display: inline-block;
  padding: 0 16px;
  height: 44px;
  line-height: 44px;
  font-size: 14px;
  color: #666;
  position: relative;
}

.category-item.active {
  color: var(--primary-color);
  font-weight: 500;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: var(--primary-color);
}

.product-grid {
  padding: 12px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.product-card {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  break-inside: avoid;
}

.product-img {
  width: 100%;
  height: 340rpx;
  background: #eee;
}

.product-info {
  padding: 10px;
}

.product-name {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 40px;
}

.product-price {
  color: #ff4d4f;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 12px;
}

.price-val {
  font-size: 18px;
  font-weight: 600;
}

.promo-tag {
  font-size: 10px;
  border: 1px solid #ff4d4f;
  border-radius: 4px;
  padding: 0 4px;
  margin-left: 6px;
  line-height: 1.4;
}

.loading-more, .no-more, .empty-state {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 13px;
}
