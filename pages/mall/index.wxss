.mall-page {
  min-height: 100vh;
  padding-bottom: 18px;
}

.mall-top {
  background: linear-gradient(135deg, #2d597b 0%, #366e9d 70%, #4a84b5 100%);
  color: #fff;
  padding: 24px 0 20px;
}

.mall-title {
  font-size: 24px;
  font-weight: 700;
}

.mall-subtitle {
  margin-top: 6px;
  font-size: 13px;
  opacity: 0.9;
}

.search-section {
  margin-top: 10px;
  margin-bottom: 10px;
}

.search-bar {
  background: #fff;
  border: 1px solid var(--border-color);
  border-radius: 999px;
  height: 40px;
  display: flex;
  align-items: center;
  padding: 0 14px;
  box-shadow: var(--shadow-soft);
}

.search-icon {
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: 14px;
}

.category-scroll {
  white-space: nowrap;
  padding: 0 12px;
  height: 46px;
  display: flex;
  align-items: center;
}

.category-item {
  display: inline-block;
  margin: 0 6px;
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 13px;
  color: var(--text-secondary);
  background: #edf2f8;
}

.category-item.active {
  color: #fff;
  background: var(--primary-color);
  font-weight: 600;
}

.product-grid {
  padding: 0 12px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.product-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid var(--border-color);
  box-shadow: var(--shadow-soft);
}

.product-img {
  width: 100%;
  height: 340rpx;
  background: #eef2f6;
}

.product-info {
  padding: 10px;
}

.product-name {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 40px;
}

.product-price {
  color: #d94848;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 12px;
}

.price-val {
  font-size: 18px;
  font-weight: 700;
}

.promo-tag {
  font-size: 10px;
  color: #d94848;
  border: 1px solid #f4b9b9;
  background: #fff3f3;
  border-radius: 999px;
  padding: 1px 7px;
  margin-left: 6px;
  line-height: 1.5;
}

.loading-more,
.no-more,
.empty-state {
  text-align: center;
  padding: 18px;
  color: var(--text-tertiary);
  font-size: 12px;
}
