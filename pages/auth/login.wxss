.login-page {
  min-height: 100vh;
  padding: 40px 18px 24px;
  background: linear-gradient(165deg, #edf4fb 0%, #f7faff 40%, #f4f7fb 100%);
}

.login-container {
  width: 100%;
  max-width: 540px;
  margin: 0 auto;
}

.login-hero {
  margin-bottom: 14px;
  text-align: center;
}

.login-title {
  font-size: 28px;
  font-weight: 700;
  color: var(--text-primary);
}

.login-subtitle {
  margin-top: 6px;
  color: var(--text-secondary);
  font-size: 14px;
}

.login-card {
  padding: 18px;
}

.tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  border-radius: 999px;
  color: var(--text-secondary);
  background: #e9eff6;
  font-size: 13px;
  font-weight: 600;
}

.tab-item.active {
  color: #fff;
  background: var(--primary-color);
}

.form-group,
.input-wrap {
  margin-bottom: 14px;
}

.label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

.code-row {
  display: flex;
  gap: 8px;
}

.code-input {
  flex: 1;
}

.code-btn {
  min-width: 108px;
  height: 44px;
  line-height: 44px;
  text-align: center;
  font-size: 13px;
  color: #fff;
  border-radius: 12px;
  background: var(--primary-color);
}

.code-btn.disabled {
  background: #c2cedc;
  color: #edf2f8;
}

.form-footer {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 10px;
}

.link {
  color: var(--primary-color);
  font-size: 13px;
}

.mt-md {
  margin-top: 6px;
}
